  "scripts": {
    "build": "tsc",
    "postinstall": "[ -n \"$CI\" ] || LISA_BOOTSTRAP=1 node node_modules/@codyswann/lisa/dist/index.js --yes --skip-git-check . 2>/dev/null || true && patch-package",
    "test:integration": "NODE_ENV=test jest --testPathPatterns=\"\\.integration[.\\\\-](test|spec)\\.(ts|tsx)$\" --passWithNoTests",
    "test": "NODE_ENV=test jest --passWithNoTests",
    "test:unit": "NODE_ENV=test jest --testPathIgnorePatterns=\"\\.integration[.\\\\-](test|spec)\\.(ts|tsx)$\" --passWithNoTests",
    "test:cov": "NODE_ENV=test jest --coverage",
    "start:local": "cp .env.localhost .env.local && STAGE=local expo start",
    "start:dev": "cp .env.development .env.local && STAGE=development expo start",
    "start:staging": "cp .env.staging .env.local && STAGE=staging expo start",
    "start:production": "cp .env.production .env.local && STAGE=production expo start",
    "fetch:graphql:schema:dev": "./scripts/fetch-graphql-schema.sh development",
    "fetch:graphql:schema:staging": "./scripts/fetch-graphql-schema.sh staging",
    "fetch:graphql:schema:production": "./scripts/fetch-graphql-schema.sh production",
    "export:web": "expo export --platform web --source-maps",
    "lighthouse:check": "lhci autorun --collect.settings.chromeFlags='--no-sandbox --disable-gpu --headless'",
    "playwright:build": "expo export --platform web",
    "playwright:test": "bun run playwright:build && playwright test",
    "playwright:test:ui": "bun run playwright:build && playwright test --ui",
    "maestro:test": "maestro test .maestro/flows",
    "maestro:test:smoke": "maestro test .maestro/flows --include-tags=smoke",
    "maestro:studio": "maestro studio",
    "pre-build:eas": "cat .gitignore > .easignore && cat .easignore.extra >> .easignore",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "oxlint && eslint . --quiet",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "lint:slow": "eslint . --config eslint.slow.config.ts --quiet",
    "types:check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format": "prettier --check . --write",
    "prepare": "node -e \"if (process.env.INIT_CWD?.includes('.serverless')) process.exit(0); process.exit(1);\" || husky install || true",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "update-node-version": "tsx scripts/update-node-version.ts",
    "knip:fix": "knip --fix",
    "sg:scan": "ast-grep scan",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:debug": "NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "lisa:update": "npx @codyswann/lisa@latest .",
    "build-and-run:local:android": "expo run:android",
    "build-and-run:local:ios": "expo run:ios",
    "security:zap": "bash scripts/zap-baseline.sh",
    "start:simulator:ios:local": "cp .env.localhost .env.local && STAGE=local expo start --ios",
    "start:simulator:ios:dev": "cp .env.development .env.local && STAGE=development expo start --ios",
    "start:simulator:ios:staging": "cp .env.staging .env.local && STAGE=staging expo start --ios",
    "start:simulator:ios:production": "cp .env.production .env.local && STAGE=production expo start --ios",
    "start:simulator:android:local": "cp .env.localhost .env.local && STAGE=local expo start --android",
    "start:simulator:android:dev": "cp .env.development .env.local && STAGE=development expo start --android",
    "start:simulator:android:staging": "cp .env.staging .env.local && STAGE=staging expo start --android",
    "start:simulator:android:production": "cp .env.production .env.local && STAGE=production expo start --android",
    "build-and-run:simulator:ios:local": "cp .env.localhost .env.local && STAGE=local expo run:ios",
    "build-and-run:simulator:ios:dev": "cp .env.development .env.local && STAGE=development expo run:ios",
    "build-and-run:simulator:ios:staging": "cp .env.staging .env.local && STAGE=staging expo run:ios",
    "build-and-run:simulator:ios:production": "cp .env.production .env.local && STAGE=production expo run:ios",
    "build-and-run:simulator:android:local": "cp .env.localhost .env.local && STAGE=local expo run:android",
    "build-and-run:simulator:android:dev": "cp .env.development .env.local && STAGE=development expo run:android",
    "build-and-run:simulator:android:staging": "cp .env.staging .env.local && STAGE=staging expo run:android",
    "build-and-run:simulator:android:production": "cp .env.production .env.local && STAGE=production expo run:android",
    "eas:login": "eas login",
    "eas:whoami": "eas whoami",
    "eas:deploy:dev": "eas build --profile dev --non-interactive",
    "eas:deploy:staging": "eas build --profile staging --non-interactive",
    "eas:deploy:production": "eas build --profile production --non-interactive",
    "eas:publish:dev": "eas update --channel dev --environment development --non-interactive",
    "eas:publish:staging": "eas update --channel staging --environment preview --non-interactive",
    "eas:publish:production": "eas update --channel production --environment production --non-interactive",
    "setup:deploy-key": "setup-deploy-key",
    "design:manifest": "node scripts/design-system/generate-gallery-manifest.mjs",
    "design:css": "node scripts/design-system/generate-global-css.mjs",
    "design:css:check": "node scripts/design-system/generate-global-css.mjs --check",
    "test:mutation": "node scripts/lisa-mutation.mjs",
    "knip:check": "knip",
    "start:atlas": "cp .env.development .env.local && STAGE=development EXPO_ATLAS=true expo start"
  },
