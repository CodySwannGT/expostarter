{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*--no-verify*": "deny",
      "*HUSKY=0*": "deny",
      "*HUSKY_SKIP_HOOKS=*": "deny",
      "*core.hooksPath*/dev/null*": "deny"
    }
  },
  "share": "disabled",
  "mcp": {
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": true,
      "_lisaManaged": true
    },
    "expo": {
      "type": "remote",
      "url": "https://mcp.expo.dev/mcp",
      "enabled": true,
      "_lisaManaged": true
    }
  },
  "instructions": [
    ".opencode/lisa-rules/eager/*.md"
  ]
}
